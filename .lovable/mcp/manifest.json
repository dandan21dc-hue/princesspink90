{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "princess-pink-mcp",
      "version": "0.1.0",
      "title": "Princess Pink MCP"
    },
    "tools": [
      {
        "name": "get_venue_info",
        "title": "Get venue info",
        "description": "Return public information about Princess Pink: what the venue offers, house rules summary, and links to key pages (store, events, compliance, conduct).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "submit_partnership_inquiry",
        "title": "Submit partnership inquiry",
        "description": "Submit a business/partnership inquiry to Princess Pink. Use for press, collaborations, or B2B outreach — NOT for guest bookings.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "description": "Contact name"
            },
            "email": {
              "type": "string",
              "format": "email",
              "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$",
              "description": "Contact email"
            },
            "company": {
              "description": "Company or organisation",
              "type": "string"
            },
            "message": {
              "type": "string",
              "minLength": 10,
              "description": "Details of the inquiry"
            }
          },
          "required": [
            "name",
            "email",
            "message"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
