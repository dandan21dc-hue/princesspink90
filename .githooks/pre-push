#!/usr/bin/env bash
# Pre-push hook: run the local reproduction of `CI / Supabase / Gate (required)`
# and block the push on failure. Wired via .githooks/ + `core.hooksPath`;
# install with `bun run hooks:install` (see scripts/install-git-hooks.sh).
#
# Behavior:
#   - Runs steps 1 + 2 of the gate (Config Validate + Lint). Step 3
#     (Migrations) is skipped by default because it needs Docker + the
#     Supabase CLI and takes ~1 min; opt in with RUN_MIGRATIONS=1.
#   - Skips entirely if the push touches no security-relevant paths
#     (allowlist below). Override with GATE_HOOK_ALWAYS=1.
#   - Skip once with `git push --no-verify` or GATE_HOOK_SKIP=1.
#
# Env:
#   SUPABASE_ACCESS_TOKEN, SUPABASE_PROJECT_REF — required for step 2.
#     If missing, the hook prints a warning and blocks the push; export
#     them (see SECURITY_SCAN.md) or use --no-verify for a fork push.

set -u -o pipefail

if [ "${GATE_HOOK_SKIP:-0}" = "1" ]; then
  echo "pre-push: GATE_HOOK_SKIP=1 set — skipping gate reproduction." >&2
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# Collect the range of commits being pushed and diff their touched paths.
# stdin format per `githooks(5) pre-push`: <local ref> <local sha> <remote ref> <remote sha>
CHANGED=""
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ -z "$local_sha" ] && continue
  # Deletion push (all-zero local sha) — nothing to scan.
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch — diff against the default remote HEAD if available.
    base="$(git merge-base "$local_sha" \
      "$(git symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null || echo HEAD)" \
      2>/dev/null || echo "")"
  else
    base="$remote_sha"
  fi
  if [ -n "$base" ]; then
    CHANGED+="$(git diff --name-only "$base" "$local_sha")"$'\n'
  else
    CHANGED+="$(git show --name-only --pretty=format: "$local_sha")"$'\n'
  fi
done

SECURITY_PATHS_RE='^(security/|scripts/(supabase-security-lint|validate-security-config|update-security-baseline|reproduce-security-gate)|supabase/(migrations|tests)/|\.github/workflows/ci\.yml|SECURITY(_SCAN)?\.md)'

if [ "${GATE_HOOK_ALWAYS:-0}" != "1" ] && [ -n "$CHANGED" ]; then
  if ! echo "$CHANGED" | grep -Eq "$SECURITY_PATHS_RE"; then
    echo "pre-push: no security-relevant files changed — skipping gate. (GATE_HOOK_ALWAYS=1 to force)"
    exit 0
  fi
fi

FLAGS=()
if [ "${RUN_MIGRATIONS:-0}" != "1" ]; then
  FLAGS+=(--skip-migrations)
fi

echo "pre-push: running local Gate reproduction (bun run security:gate:local ${FLAGS[*]:-})…"
if ! bun run security:gate:local -- "${FLAGS[@]}"; then
  echo "" >&2
  echo "pre-push: gate reproduction FAILED — push blocked." >&2
  echo "  Fix the failure above, or bypass once with:  git push --no-verify" >&2
  exit 1
fi
