# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# App Origin Configuration
# Override the public app origin for emails (highest priority).
# Leave unset to auto-detect from request headers (x-forwarded-host, host, origin).
# PUBLIC_APP_URL=https://app.example.com

# Alternative fallback if PUBLIC_APP_URL is not set
# SITE_URL=https://site.example.com

# Stripe Configuration
VITE_STRIPE_PUBLIC_KEY=pk_live_your-key-here
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email Configuration (Lovable)
# Used by @lovable.dev/email-js for sending transactional emails
LOVABLE_EMAIL_API_KEY=your-api-key

# AI/LLM Configuration (Optional)
OPENAI_API_KEY=sk_your-key-here

# Error Reporting (Optional)
# If using Lovable error reporting
LOVABLE_ERROR_REPORTING_KEY=your-key-here

# Development / Local Override (development only)
# Uncomment to override for local testing:
# PUBLIC_APP_URL=http://localhost:5173

# Database
# Direct connection string for migrations and tests (not pooled).
# Used by supabase db test and CI runners.
DIRECT_DB_URL=postgresql://user:password@localhost:5432/princesspink90
